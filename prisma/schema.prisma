generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int           @id @default(autoincrement())
  uuid         String        @unique @default(dbgenerated("gen_random_uuid()"))
  name         String
  email        String        @unique
  phone        String?
  passwordHash String        @map("password_hash")
  role         Role          @default(employee)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")
  transactions Transaction[]

  @@map("users")
}

model Product {
  id               Int               @id @default(autoincrement())
  uuid             String            @unique @default(dbgenerated("gen_random_uuid()"))
  name             String
  urlpathImage     String?           @map("urlpath_image")
  description      String?
  category         Category
  price            Decimal           @default(0) @db.Decimal(15, 2)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")
  transactionItems TransactionItem[]

  @@map("products")
}

model Transaction {
  id              Int               @id @default(autoincrement())
  uuid            String            @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNumber   String            @unique @map("invoice_number") @db.VarChar(50)
  userId          Int               @map("user_id")
  customerName    String            @map("customer_name") @db.VarChar(100)
  totalAmount     Decimal           @default(0) @map("total_amount") @db.Decimal(15, 2)
  discount        Decimal           @default(0) @db.Decimal(15, 2)
  tax             Decimal           @default(0) @db.Decimal(15, 2)
  grandTotal      Decimal           @default(0) @map("grand_total") @db.Decimal(15, 2)
  paymentMethod   String            @map("payment_method") @db.VarChar(20)
  paymentStatus   String?           @default("pending") @map("payment_status") @db.VarChar(20)
  orderType       String            @map("order_type") @db.VarChar(20)
  notes           String?
  transactionDate DateTime?         @default(now()) @map("transaction_date") @db.Timestamp(6)
  createdAt       DateTime?         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime?         @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamp(6)
  items           TransactionItem[]
  user            User              @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([invoiceNumber], map: "idx_transactions_invoice_number")
  @@index([userId], map: "idx_transactions_user_id")
  @@map("transactions")
}

model TransactionItem {
  id            Int         @id @default(autoincrement())
  uuid          String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionId Int         @map("transaction_id")
  productId     Int         @map("product_id")
  productName   String      @map("product_name") @db.VarChar(200)
  quantity      Int
  unitPrice     Decimal     @map("unit_price") @db.Decimal(15, 2)
  subtotal      Decimal?    @default(dbgenerated("((quantity)::numeric * unit_price)")) @db.Decimal(15, 2)
  createdAt     DateTime?   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt     DateTime?   @map("deleted_at") @db.Timestamp(6)
  product       Product     @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([transactionId], map: "idx_transaction_items_transaction_id")
  @@map("transaction_items")
}

enum Role {
  employee
  admin
  customer
}

enum Category {
  food
  beverage
  dessert
}

enum PaymentMethod {
  cash
  transfer
  qris
}

enum PaymentStatus {
  paid
  pending
  failed
  refund
}

enum OrderType {
  dine_in
  takeaway
}
