                  "pm.expect(json.status).to.eql('success');",
                  "pm.expect(json.data.token).to.exist;",
                  "pm.environment.set('adminToken', json.data.token);",
                  "pm.environment.set('adminId', json.data.user.id);",
                  "pm.environment.set('userId', json.data.user.id);",
                  "console.log('✅ Admin token saved!')"
                ],
                "type": "text/javascript"
              }
            }
