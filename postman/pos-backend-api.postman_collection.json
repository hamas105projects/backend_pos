      "name": "08. Trans Admin/Cancel",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + pm.environment.get('adminToken')});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "item": [
        {
          "name": "✅ Mark Paid",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"paymentStatus\":\"paid\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/{{transactionId}}/payment-status",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "{{transactionId}}", "payment-status"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Paid OK', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "❌ Cancel (User)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions/{{transactionId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "{{transactionId}}", "cancel"]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.upsert({key: 'Authorization', value: 'Bearer ' + pm.environment.get('userToken')});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Cancel OK', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "📊 Daily Report",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions/reports/daily?date=2024-10-20",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "reports", "daily"],
              "query": [{"key": "date", "value": "2024-10-20"}]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Daily Report', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "📈 Monthly Report",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions/reports/monthly?year=2024&month=10",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "reports", "monthly"],
              "query": [
                {"key": "year", "value": "2024"},
                {"key": "month", "value": "10"}
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Monthly Report', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
