{
  "info": {
    "name": "POS Backend API - Complete Tests",
    "_postman_id": "pos-api-full",
    "description": "Full Postman collection for ALL endpoints in src/. Covers health, auth, users, products, transactions, reports with tests & auto-token.\n\n**Setup:**\n1. `npm run db:push && npx prisma db seed`\n2. `npm run dev` (server on :3000)\n3. Import & run Authentication first\n4. Variables auto-update IDs/tokens\n\n{{baseUrl}}=http://localhost:3000/api/v1\n\n✅ 30+ requests | Tests on all | Auth flows | Multipart upload",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:3000/api/v1"},
    {"key": "rootUrl", "value": "http://localhost:3000"},
    {"key": "userToken", "value": ""},
    {"key": "adminToken", "value": ""},
    {"key": "productId", "value": "1"},
    {"key": "userId", "value": "1"},
    {"key": "transactionId", "value": "1"},
    {"key": "invoiceNumber", "value": "INV-001"},
    {"key": "adminId", "value": "1"}
  ],
  "auth": {"type": "noauth"},
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Check server ready",
          "pm.sendRequest(pm.variables.replaceIn('{{rootUrl}}/health'), (err, res) => {",
          "  if (res.code !== 200) console.log('⚠️ Server not ready');",
          "});"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
